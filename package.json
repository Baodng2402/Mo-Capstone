{
  "name": "my-expo-app",
  "version": "1.0.0",
  "scripts": {
    "android": "expo start --android",
    "build:android": "eas build -p android --profile preview",
    "build:development": "eas build -p android --profile development",
    "export:android": "EXPO_USE_WATCHMAN=0 expo export --platform android",
    "export:web": "EXPO_USE_WATCHMAN=0 expo export --platform web",
    "ios": "expo start --ios",
    "start": "expo start",
    "prebuild": "expo prebuild",
    "prepare": "husky",
    "test": "jest",
    "test:watch": "jest --watch",
    "typecheck": "tsc --noEmit",
    "lint:staged": "lint-staged",
    "lint": "eslint \"**/*.{js,jsx,ts,tsx}\" && prettier -c \"**/*.{js,jsx,ts,tsx,json,md,yml,yaml,css}\"",
    "verify": "npm run typecheck && npm run lint && npm test -- --runInBand --passWithNoTests",
    "format": "eslint \"**/*.{js,jsx,ts,tsx}\" --fix && prettier \"**/*.{js,jsx,ts,tsx,json,md,yml,yaml,css}\" --write",
    "web": "expo start --web"
  },
  "dependencies": {
    "@cloudinary/url-gen": "^1.22.0",
    "@hookform/resolvers": "^5.2.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@tailwindcss/postcss": "^4.1.13",
    "@tanstack/react-query": "^5.100.4",
    "expo": "^54.0.0",
    "expo-auth-session": "~7.0.10",
    "expo-camera": "~17.0.10",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.8",
    "expo-dev-client": "~6.0.20",
    "expo-file-system": "~19.0.21",
    "expo-image-manipulator": "~14.0.8",
    "expo-image-picker": "~17.0.10",
    "expo-linking": "~8.0.11",
    "expo-location": "~19.0.8",
    "expo-network": "~8.0.8",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-sqlite": "~16.0.10",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.10",
    "lucide-react-native": "^1.11.0",
    "nativewind": "preview",
    "postcss": "^8.5.6",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.73.1",
    "react-native": "0.81.5",
    "react-native-css": "latest",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-maps": "1.20.1",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.5.1",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@testing-library/react-native": "^13.3.3",
    "@types/react": "~19.1.10",
    "eslint": "^9.25.1",
    "eslint-config-expo": "~10.0.0",
    "eslint-config-prettier": "^10.1.2",
    "husky": "^9.1.7",
    "jest": "~29.7.0",
    "jest-expo": "~54.0.17",
    "lint-staged": "^16.4.0",
    "prettier": "^3.2.5",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "react-test-renderer": "^19.1.0",
    "tailwindcss": "^4.1.13",
    "typescript": "~5.9.2"
  },
  "main": "expo-router/entry",
  "jest": {
    "preset": "jest-expo",
    "watchman": false
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml,css}": [
      "prettier --write"
    ]
  },
  "overrides": {
    "lightningcss": "1.30.1"
  },
  "private": true
}
