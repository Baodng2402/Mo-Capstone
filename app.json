{
  "expo": {
    "name": "mo_capstone",
    "slug": "mo_capstone",
    "scheme": "glowscan",
    "version": "1.0.0",
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "experiments": {
      "tsconfigPaths": true
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "GlowScan uses the camera to capture face images for skin analysis."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "GlowScan uses your photo library to select face images for skin analysis."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "GlowScan uses your location to find nearby clinics and spas."
        }
      ],
      "expo-secure-store",
      "expo-web-browser",
      "expo-sqlite"
    ],
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "bundleIdentifier": "com.glowscan.mobile",
      "supportsTablet": true
    },
    "android": {
      "package": "com.glowscan.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      }
    }
  }
}
